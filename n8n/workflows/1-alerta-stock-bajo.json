                        "type": "main",
                        "index": 0
                    },
                    {
                        "node": "Preparar Alertas",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Enviar a Telegram": {
            "main": [
                [
                    {
                        "node": "Marcar como Notificado",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Preparar Alertas": {
            "main": [
                [
                    {
                        "node": "Crear Alertas en BD",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "active": true,
    "settings": {
        "executionOrder": "v1"
    },
